<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Splash screen theme -->
    <style name="Theme.Tilfaeldig.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_color_back</item>
        <item name="postSplashScreenTheme">@style/Theme.Tilfaeldig</item>
    </style>

    <!-- Base app theme -->
    <style name="Base.Theme.Tilfaeldig" parent="Theme.Material3.Dark.NoActionBar">

        <!-- Background -->
        <item name="android:windowBackground">@color/background</item>

        <!-- Text -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Material 3 -->
        <item name="colorSurface">@color/background</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>

    </style>

    <style name="Theme.Tilfaeldig" parent="Base.Theme.Tilfaeldig" />

</resources>
